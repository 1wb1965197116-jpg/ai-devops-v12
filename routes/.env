const express = require("express");
const Project = require("../models/Project");

const router = express.Router();

// SAVE ENV
router.post("/save", async (req, res) => {
  const { userId, name, env } = req.body;

  let project = await Project.findOne({ userId, name });

  if (!project) {
    project = await Project.create({ userId, name, env, versions: [] });
  } else {
    project.env = env;
    await project.save();
  }

  res.json(project);
});

// VERSION
router.post("/version", async (req, res) => {
  const { name } = req.body;

  const project = await Project.findOne({ name });

  project.versions.push(project.env);
  await project.save();

  res.json({ status: "version saved" });
});

// ROLLBACK
router.post("/rollback", async (req, res) => {
  const { name } = req.body;

  const project = await Project.findOne({ name });

  const last = project.versions.pop();
  project.env = last;

  await project.save();

  res.json({ status: "rolled back" });
});

module.exports = router;
